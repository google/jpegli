prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@PKGCONFIG_TARGET_LIBS@
includedir=@PKGCONFIG_TARGET_INCLUDES@

Name: libjpegli_cms
Description: CMS support library for libjpegli
Version: @JPEGLI_LIBRARY_VERSION@
@JPEGLI_REQUIRES_TYPE@: @JPEGLI_CMS_LIBRARY_REQUIRES@
Libs: -L${libdir} -ljpegli_cms @JPEGLI_CMS_PUBLIC_LIBS@
Libs.private: @JPEGLI_CMS_PRIVATE_LIBS@
Cflags: -I${includedir}
Cflags.private: -DJPEGLI_CMS_STATIC_DEFINE
